#!/bin/sh
# nurlweb/bin/nurlweb — NurlWeb project scaffolding CLI
#
# Usage:
#   nurlweb new my-app          Create a new nurlweb project
#   nurlweb version             Print version
#   nurlweb help                Print this help
#
# The `new` command scaffolds a project directory with:
#   my-app/
#     nurlweb/     → git clone of nurlweb framework
#     app.nu       → main application entry point
#     build.sh     → build script
#     .gitignore

set -eu

NURLWEB_REPO="https://github.com/clawbolt/nurlweb"
NURLWEB_VERSION="0.3.0.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATES_DIR="$SCRIPT_DIR/../templates"

# ── help ──────────────────────────────────────────────────────────────

print_help() {
    cat <<EOF
nurlweb v${NURLWEB_VERSION} — NurlWeb project scaffolding

Usage:
  nurlweb new <project-name>    Create a new nurlweb project
  nurlweb version               Print version
  nurlweb help                  Print this help

Example:
  nurlweb new my-api
  cd my-api && sh build.sh
EOF
}

# ── version ───────────────────────────────────────────────────────────

print_version() {
    echo "nurlweb v${NURLWEB_VERSION}"
}

# ── new ────────────────────────────────────────────────────────────────

cmd_new() {
    name="$1"
    if [ -d "$name" ]; then
        echo "Error: directory '$name' already exists" >&2
        exit 1
    fi

    echo "Creating nurlweb project: $name"

    mkdir -p "$name"

    # ── Clone nurlweb framework ────────────────────────────────────
    echo "  Cloning nurlweb framework..."
    if command -v git >/dev/null 2>&1; then
        git clone --quiet "$NURLWEB_REPO" "$name/nurlweb" 2>/dev/null || {
            echo "  Warning: git clone failed — copying from templates instead" >&2
            cp -R "$SCRIPT_DIR/.." "$name/nurlweb"
        }
    else
        cp -R "$SCRIPT_DIR/.." "$name/nurlweb"
    fi

    # ── Generate app.nu from template ──────────────────────────────
    if [ -f "$TEMPLATES_DIR/app.nu.tmpl" ]; then
        sed "s/{{PROJECT_NAME}}/$name/g" "$TEMPLATES_DIR/app.nu.tmpl" > "$name/app.nu"
    else
        # Fallback inline template
        cat > "$name/app.nu" <<NURL
// $name/app.nu — Generated by nurlweb v${NURLWEB_VERSION}
//
// Edit this file to define your routes and application logic.

\$ \`nurlweb/nurlweb.nu\`

@ main → i {
    : App app ( app_new \`127.0.0.1\` 3900 )

    ( app_get app \`/\`
        \\ HttpRequest req Params params → HttpResponse {
            : Ctx ctx ( ctx_new req params )
            ^ ( ctx_html ctx 200 \`<h1>$name</h1>\\n\` )
        })

    : !v NetErr rr ( app_serve app )
    ( app_free app )

    ?? rr {
        T _ → { ^ 0 }
        F _ → { ^ 1 }
    }
}
NURL
    fi

    # ── Generate build.sh ──────────────────────────────────────────
    cat > "$name/build.sh" <<BUILD
#!/bin/sh
# $name/build.sh — Build script for $name
set -eu

NURLC="\${NURLC:-nurlc}"
RUNTIME="\${NURL_RUNTIME:-nurlweb/../stdlib/runtime.o}"

echo "Building $name..."
"\$NURLC" app.nu > app.ll 2>/dev/null
clang -O2 app.ll "\$RUNTIME" -lm -lpthread \\
    \$(pkg-config --libs libcurl 2>/dev/null || echo "-lcurl") \\
    \$(pkg-config --libs openssl 2>/dev/null || echo "-lssl -lcrypto") \\
    \$(pkg-config --libs sqlite3 2>/dev/null || echo "-lsqlite3") \\
    \$(pkg-config --libs zlib 2>/dev/null || echo "-lz") \\
    \$(pkg-config --libs libzstd 2>/dev/null || echo "-lzstd") \\
    -o app 2>/dev/null
echo "Done. Run: ./app"
BUILD
    chmod +x "$name/build.sh"

    # ── Generate .gitignore ────────────────────────────────────────
    cat > "$name/.gitignore" <<GITIGNORE
*.ll
*.o
app
GITIGNORE

    echo ""
    echo "Project '$name' created!"
    echo ""
    echo "  cd $name"
    echo "  sh build.sh"
    echo "  ./app"
    echo ""
    echo "Then open http://127.0.0.1:3900"
}

# ── Main ──────────────────────────────────────────────────────────────

case "${1:-help}" in
    new)
        if [ $# -lt 2 ]; then
            echo "Usage: nurlweb new <project-name>" >&2
            exit 1
        fi
        cmd_new "$2"
        ;;
    version)
        print_version
        ;;
    help|--help|-h)
        print_help
        ;;
    *)
        echo "Unknown command: $1" >&2
        print_help
        exit 1
        ;;
esac
