            ?? name {
                T n → { ^ ( ctx_ok ctx n ) }
                F  → { ^ ( ctx_not_found ctx `missing name\n` ) }
            }
        })

    // ── Serve ─────────────────────────────────────────────────────

    ( nurl_print `{{PROJECT_NAME}} on http://127.0.0.1:3900\n` )

    : !v NetErr rr ( app_serve app )
    ( app_free app )

    ?? rr {
        T _ → { ^ 0 }
        F _ → { ^ 1 }
    }
}
