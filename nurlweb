#!/usr/bin/env bash
# nurlweb — CLI for the NurlWeb framework
# Usage: nurlweb <command> [args]
#
# Commands:
#   dev [port]     Start development server with hot-reload
#   g <name>       Generate a new nurlweb project
#   build <file>   Compile a .nu file
#   version        Show version

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION_FILE="$SCRIPT_DIR/VERSION"
VERSION="0.4.0.0"
[ -f "$VERSION_FILE" ] && VERSION=$(cat "$VERSION_FILE")

# Locate nurlc
NURL_REPO="/Users/t77yq/Documents/Codex/2026-05-24/nurl-lang-nurl-https-github-com-2"
NURLC="${NURL_REPO}/build/nurlc"
RUNTIME="${NURL_REPO}/stdlib/runtime.o"

if [ ! -x "$NURLC" ]; then
    echo "Error: nurlc not found at $NURLC" >&2
    exit 1
fi

usage() {
    echo "NurlWeb CLI v${VERSION}"
    echo ""
    echo "Usage: nurlweb <command> [args]"
    echo ""
    echo "Commands:"
    echo "  dev [port]       Start dev server (default port 3900)"
    echo "  g <name>         Generate new nurlweb project"
    echo "  build <file>     Compile .nu file"
    echo "  version          Show version"
    exit 0
}

cmd_dev() {
    local port="${1:-3900}"
    local app_file="$SCRIPT_DIR/examples/hello.nu"
    
    echo "🔧 Building..."
    "$NURLC" "$app_file" > /tmp/nurlweb_dev.ll 2>/dev/null
    
    CURL_LIBS=($(pkg-config --libs libcurl 2>/dev/null || echo "-lcurl"))
    OPENSSL_LIBS=($(pkg-config --libs openssl 2>/dev/null || echo "-lssl -lcrypto"))
    SQLITE3_LIBS=($(pkg-config --libs sqlite3 2>/dev/null || echo "-lsqlite3"))
    ZLIB_LIBS=($(pkg-config --libs zlib 2>/dev/null || echo "-lz"))
    
    clang -O2 /tmp/nurlweb_dev.ll "$RUNTIME" -lm -lpthread \
        "${CURL_LIBS[@]}" "${OPENSSL_LIBS[@]}" "${SQLITE3_LIBS[@]}" "${ZLIB_LIBS[@]}" \
        -o /tmp/nurlweb_dev 2>/dev/null || {
        echo "Error: link failed" >&2
        exit 1
    }
    
    echo "🚀 Starting dev server on http://127.0.0.1:${port}"
    echo "   Press Ctrl+C to stop"
    /tmp/nurlweb_dev
}

cmd_generate() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        echo "Usage: nurlweb g <project-name>" >&2
        exit 1
    fi
    
    if [ -d "$name" ]; then
        echo "Error: directory '$name' already exists" >&2
        exit 1
    fi
    
    echo "📦 Generating nurlweb project: $name"
    mkdir -p "$name"
    
    # Create app.nu
    cat > "$name/app.nu" << 'NUEOF'
// {{name}}/app.nu — Generated by nurlweb
//
// Entry point for {{name}} web application.

$ `nurlweb/app.nu`

@ main → i {
    : App a ( app_new `127.0.0.1` 3900 )

    ( app_get a `/`
        \ HttpRequest req Params params → HttpResponse {
            ^ ( response_text 200 `Hello from {{name}}!\n` )
        })

    : !v NetErr rr ( app_serve a )
    ?? rr {
        T _ → { ^ 0 }
        F e → {
            ( nurl_eprint `Failed to start server\n` )
            ( app_free a )
            ^ 1
        }
    }
}
NUEOF
    sed -i '' "s/{{name}}/$name/g" "$name/app.nu"
    
    echo "✅ Project created at $name/"
    echo "   cd $name && nurlweb dev"
}

cmd_build() {
    local file="${1:-}"
    if [ -z "$file" ]; then
        echo "Usage: nurlweb build <file.nu>" >&2
        exit 1
    fi
    
    local base="${file%.nu}"
    echo "🔨 Compiling $file..."
    "$NURLC" "$file" > "${base}.ll" 2>/dev/null
    echo "✅ Generated ${base}.ll"
}

cmd_version() {
    echo "NurlWeb v${VERSION}"
}

# ── Main ──────────────────────────────────────────────────────────────

case "${1:-}" in
    dev)     shift; cmd_dev "$@" ;;
    g)       shift; cmd_generate "$@" ;;
    build)   shift; cmd_build "$@" ;;
    version) cmd_version ;;
    -h|--help|"") usage ;;
    *) echo "Unknown command: $1" >&2; usage ;;
esac
